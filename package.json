{
  "name": "governance-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/db-provider.mjs",
    "dev": "next dev",
    "build": "node scripts/db-provider.mjs && prisma generate && next build",
    "start": "next start",
    "start:prod": "node scripts/db-provider.mjs && prisma db push --skip-generate --accept-data-loss && node prisma/seed.mjs && next start -H 0.0.0.0",
    "lint": "next lint",
    "db:push": "node scripts/db-provider.mjs && prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "postinstall": "node scripts/db-provider.mjs && prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.20",
    "nodemailer": "^7.0.13",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.4",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.78.0",
    "react-pdf": "^9.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.23",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
