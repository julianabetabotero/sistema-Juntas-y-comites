# ─────────────────────────────────────────────────────────────
# Base de datos
# Local (SQLite): archivo en el proyecto.
DATABASE_URL="file:./dev.db"
# Producción (Railway / PostgreSQL): cambia también el `provider` en
# prisma/schema.prisma a "postgresql". Ejemplo:
# DATABASE_URL="postgresql://user:password@host:5432/governance_db"

# ─────────────────────────────────────────────────────────────
# Auth (NextAuth.js v5)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
# En NextAuth v5 también se acepta AUTH_SECRET / AUTH_URL.
AUTH_SECRET="igual-que-NEXTAUTH_SECRET"
AUTH_TRUST_HOST="true"

# ─────────────────────────────────────────────────────────────
# Almacenamiento de documentos
STORAGE_TYPE="local"            # "local" | "s3"
LOCAL_STORAGE_PATH="./uploads"
# Opción S3 (si STORAGE_TYPE="s3"):
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# ─────────────────────────────────────────────────────────────
# Anthropic (módulo de IA) — opcional para arrancar
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────────────────────────
# Email (citaciones) — opcional para arrancar
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="plataforma@empresa.com"
